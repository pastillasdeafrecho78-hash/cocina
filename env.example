# ============================================
# CONFIGURACIÓN MÍNIMA REQUERIDA
# ============================================
# DATABASE_URL y AUTH_SECRET (o JWT_SECRET) son necesarios para empezar
# El resto se configura desde la UI cuando el admin inicia sesión

# Base de datos PostgreSQL
# Local: suele ser localhost:5432
DATABASE_URL="postgresql://postgres:password@localhost:5432/comandas_db"
# P3005 en Vercel: el build (scripts/vercel-build.sh) hace baseline automático en el servidor; no hace falta tu máquina.
# Opcional en local: npm run db:baseline:resolve-all
# Solo producción (Vercel + Supabase): URI para migraciones en el build.
# - Opción A: "Direct connection" (db.xxx.supabase.co:5432) — el script añade ?sslmode=require si falta.
# - Si Prisma devuelve P1001 desde Vercel hacia db.*: prueba "Session pooler" en Supabase (puerto 5432, no 6543):
#   usuario postgres.PROJECT_REF, host aws-REGION.pooler.supabase.com — admite migraciones mejor que el pooler transaccional.
# La app puede seguir usando DATABASE_URL con pooler :6543.
# DIRECT_URL="postgresql://postgres:PASSWORD@db.xxxxx.supabase.co:5432/postgres"

# NextAuth / sesión (OBLIGATORIO - mín. 32 caracteres). Si no defines AUTH_SECRET, se usa JWT_SECRET.
# openssl rand -base64 32
AUTH_SECRET="tu-secret-mínimo-32-caracteres-aqui"
JWT_SECRET="tu-secret-mínimo-32-caracteres-aqui"

# Google OAuth (opcional).
# NEXT_PUBLIC_AUTH_GOOGLE_ENABLED se infiere en next.config si existen ambas.
# AUTH_GOOGLE_ID="..."
# AUTH_GOOGLE_SECRET="..."

# Meta/Facebook OAuth (opcional)
# AUTH_META_ID="..."
# AUTH_META_SECRET="..."

# ============================================
# CONFIGURACIÓN OPCIONAL (Para desarrollo avanzado)
# ============================================
# Estas variables son opcionales. La configuración fiscal y de pagos
# se hace desde la UI cuando el admin inicia sesión por primera vez.

# URL pública para webhooks de Clip. En Vercel suele bastar VERCEL_URL automático; si usas dominio propio:
# PUBLIC_BACKEND_BASE_URL="https://cocina-silk.vercel.app"

# Ambiente (opcional, por defecto es "development")
# NODE_ENV="development"

# KDS configurable (opcional). En Vercel requiere redeploy al cambiar por ser NEXT_PUBLIC.
# Si está apagado, Cocina/Barra siguen funcionando con el destino legacy.
# NEXT_PUBLIC_KDS_SECCIONES_CONFIGURABLES="1"

# Inventario manual MVP (opcional). En Vercel requiere redeploy al cambiar por ser NEXT_PUBLIC.
# No descuenta ventas automáticamente; solo habilita artículos, compras/entradas y ajustes manuales.
# NEXT_PUBLIC_INVENTARIO_MVP="1"

# Reembolsos en caja (opcional). En Vercel requiere redeploy al cambiar por ser NEXT_PUBLIC.
# Mantiene el pago original y registra reembolsos separados para corte/reportes.
# NEXT_PUBLIC_REEMBOLSOS_CAJA="1"

# Layout avanzado de mesas (opcional). En Vercel requiere redeploy al cambiar por ser NEXT_PUBLIC.
# Permite forma circular/rectangular y ancho/alto visual en el plano de mesas.
# NEXT_PUBLIC_MESAS_LAYOUT_AVANZADO="1"

# Stripe (para pagos con tarjeta, Apple Pay, Google Pay)
# Obtén las claves en https://dashboard.stripe.com/apikeys
# STRIPE_SECRET_KEY="sk_test_..."
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
