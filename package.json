{
  "name": "app-comandas-restaurante",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "node --max-old-space-size=4096 node_modules/next/dist/bin/next dev",
    "build": "bash scripts/vercel-build.sh",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "dotenv -e .env.local -- prisma generate",
    "db:push": "dotenv -e .env.local -- prisma db push",
    "db:migrate": "dotenv -e .env.local -- prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:baseline:resolve-all": "bash scripts/prisma-baseline-resolve-all.sh",
    "db:studio": "dotenv -e .env.local -- prisma studio",
    "db:seed": "dotenv -e .env.local -- tsx scripts/seed.ts",
    "ensure:external-order-actors": "dotenv -e .env.local -- tsx scripts/ensure-external-order-actors.ts",
    "verify:env": "tsx scripts/verify-env.ts",
    "tunnel": "node scripts/start-tunnel.js",
    "tunnel:simple": "node scripts/ngrok-simple.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@heroicons/react": "^2.0.18",
    "@hookform/resolvers": "^3.3.4",
    "@prisma/client": "^5.22.0",
    "@stripe/react-stripe-js": "^5.6.0",
    "@stripe/stripe-js": "^8.7.0",
    "bcryptjs": "^2.4.3",
    "conekta": "^7.0.6",
    "date-fns": "^3.0.6",
    "jose": "^6.1.0",
    "next": "^14.2.35",
    "next-auth": "^5.0.0-beta.30",
    "ngrok": "^5.0.0-beta.2",
    "pdfkit": "^0.14.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.47.0",
    "react-hot-toast": "^2.4.1",
    "recharts": "^3.8.0",
    "socket.io": "^4.7.4",
    "socket.io-client": "^4.7.4",
    "stripe": "^20.3.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.10.6",
    "@types/pdfkit": "^0.13.4",
    "@types/react": "^18.2.46",
    "@types/react-dom": "^18.2.18",
    "autoprefixer": "^10.4.16",
    "dotenv": "^17.2.3",
    "dotenv-cli": "^7.4.4",
    "eslint": "^8.56.0",
    "eslint-config-next": "14.0.0",
    "postcss": "^8.4.32",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.3.6",
    "tsx": "^4.7.0",
    "typescript": "^5.2.2",
    "vitest": "^4.1.3"
  }
}
