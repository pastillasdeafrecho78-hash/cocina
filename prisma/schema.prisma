// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EstadoMesa {
  LIBRE
  OCUPADA
  CUENTA_PEDIDA
  RESERVADA
}

enum TipoPedido {
  EN_MESA
  PARA_LLEVAR
  A_DOMICILIO
  WHATSAPP
}

enum EstadoComanda {
  PENDIENTE
  EN_PREPARACION
  LISTO
  SERVIDO
  PAGADO
  CANCELADO
}

enum OrigenComanda {
  STAFF_DASHBOARD
  PUBLIC_LINK
  EXTERNAL_API
}

enum EstadoSolicitudPedido {
  PENDIENTE
  EN_COLA
  APROBADA
  RECHAZADA
  EXPIRADA
}

enum OrigenSolicitudPedido {
  PUBLIC_LINK_GENERAL
  PUBLIC_LINK_MESA
}

enum TipoPedidoSolicitud {
  MESA
  PARA_LLEVAR
  ENVIO
}

enum TipoCategoria {
  COMIDA
  BEBIDA
  POSTRE
  ENTRADA
}

enum TipoModificador {
  INGREDIENTE
  COCCION
  TAMANO
  EXTRAS
}

enum EstadoItem {
  PENDIENTE
  EN_PREPARACION
  LISTO
  ENTREGADO
}

enum DestinoItem {
  COCINA
  BARRA
}

enum ScopeVistaDashboard {
  USER
  GLOBAL
  ROL
}

enum OAuthProvider {
  google
  facebook
}

enum MenuStrategy {
  EMPTY
  CLONE
  SHARED
}

model Organizacion {
  id        String   @id @default(cuid())
  nombre    String
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  restaurantes  Restaurante[]
  miembros      OrganizacionMiembro[]
  usuariosActivos Usuario[] @relation("UsuarioActiveOrganizacion")
  codigosVinculacion CodigoVinculacionSucursal[]
}

model Rol {
  id          String           @id @default(cuid())
  nombre      String
  codigo      String?          @unique
  descripcion String?
  permisos    Json // ["mesas", "comandas", "carta", ...] o ["*"] para admin
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  usuarios    Usuario[]
  dashboards  DashboardVista[]
  invitaciones Invitacion[]
  codigosVinculacion CodigoVinculacionSucursal[]
  miembrosSucursal    SucursalMiembro[]
  miembrosOrganizacion OrganizacionMiembro[]
}

model Restaurante {
  id        String   @id @default(cuid())
  nombre    String
  slug      String?  @unique
  activo    Boolean  @default(true)
  menuStrategy MenuStrategy @default(EMPTY)
  menuSourceRestauranteId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organizacionId String?
  organizacion   Organizacion? @relation(fields: [organizacionId], references: [id], onDelete: SetNull)
  menuSourceRestaurante Restaurante? @relation("RestauranteMenuSource", fields: [menuSourceRestauranteId], references: [id], onDelete: SetNull)
  menuLinkedRestaurantes Restaurante[] @relation("RestauranteMenuSource")

  usuarios                 Usuario[]
  usuariosActivos          Usuario[]          @relation("UsuarioActiveRestaurante")
  mesas                    Mesa[]
  clientes                 Cliente[]
  comandas                 Comanda[]
  categorias               Categoria[]
  modificadores            Modificador[]
  plantas                  PlantaRestaurante[]
  configuracion            ConfiguracionRestaurante?
  auditorias               Auditoria[]
  cortesX                  CorteX[]
  cortesZ                  CorteZ[]
  dashboards               DashboardVista[]
  integracionClip          IntegracionClip?
  terminalesClip           ClipTerminal[]
  turnosCaja               TurnoCaja[]
  invitaciones             Invitacion[]
  miembrosSucursal         SucursalMiembro[]
  integracionPedidosApi    IntegracionPedidosApi?
  codigosVinculacion       CodigoVinculacionSucursal[]
  mesasPublicLinks         MesaPublicLink[]
  solicitudesPedido        SolicitudPedido[]

  @@index([organizacionId])
  @@index([menuSourceRestauranteId])
}

model Usuario {
  id           String    @id @default(cuid())
  email        String
  nombre       String
  apellido     String
  password     String?
  rolId        String // LEGACY_COMPAT: fallback temporal hasta deprecacion total por membresia activa
  restauranteId String // LEGACY_COMPAT: sucursal base historica, no usar como tenant operativo
  activeOrganizacionId String?
  activeRestauranteId  String?
  activo       Boolean   @default(true)
  ultimoAcceso DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  rol               Rol                @relation(fields: [rolId], references: [id], onDelete: Restrict)
  restaurante       Restaurante        @relation(fields: [restauranteId], references: [id], onDelete: Restrict)
  activeOrganizacion Organizacion?     @relation("UsuarioActiveOrganizacion", fields: [activeOrganizacionId], references: [id], onDelete: SetNull)
  activeRestaurante  Restaurante?      @relation("UsuarioActiveRestaurante", fields: [activeRestauranteId], references: [id], onDelete: SetNull)
  organizaciones    OrganizacionMiembro[]
  sucursales        SucursalMiembro[]
  cuentasOAuth      CuentaOAuth[]
  comandasCreadas   Comanda[]          @relation("ComandaCreadaPor")
  comandasAsignadas Comanda[]          @relation("ComandaAsignadaA")
  comandasCanceladas Comanda[]         @relation("ComandaCanceladaPor")
  historialComandas ComandaHistorial[] @relation("ComandaHistorialUsuario")
  auditoria         Auditoria[]        @relation("AuditoriaUsuario")
  solicitudesRevisadas SolicitudPedido[] @relation("SolicitudPedidoRevisadaPor")
  colaboracionesComanda ComandaColaborador[]
  cortesX           CorteX[]
  cortesZ           CorteZ[]
  turnosCaja        TurnoCaja[]
  dashboards        DashboardVista[]
  codigosVinculacion CodigoVinculacionSucursal[] @relation("CodigoVinculacionCreadoPor")

  @@unique([restauranteId, email])
  @@index([rolId])
  @@index([restauranteId])
  @@index([activeOrganizacionId])
  @@index([activeRestauranteId])
}

model OrganizacionMiembro {
  id            String   @id @default(cuid())
  usuarioId     String
  organizacionId String
  rolId         String?
  esOwner       Boolean  @default(false)
  activo        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  usuario      Usuario      @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  organizacion Organizacion @relation(fields: [organizacionId], references: [id], onDelete: Cascade)
  rol          Rol?         @relation(fields: [rolId], references: [id], onDelete: SetNull)

  @@unique([usuarioId, organizacionId])
  @@index([organizacionId])
  @@index([organizacionId, activo])
  @@index([usuarioId, activo])
  @@index([rolId])
}

model SucursalMiembro {
  id            String   @id @default(cuid())
  usuarioId     String
  restauranteId String
  rolId         String?
  activo        Boolean  @default(true)
  esPrincipal   Boolean  @default(false)
  horarioInicioMin Int? // Minutos desde 00:00 (ej. 480 = 08:00)
  horarioFinMin    Int? // Minutos desde 00:00 (ej. 1320 = 22:00)
  diasLaborales    String? // CSV simple: "1,2,3,4,5,6,0" (lunes=1 ... domingo=0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  usuario     Usuario     @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  restaurante Restaurante @relation(fields: [restauranteId], references: [id], onDelete: Cascade)
  rol         Rol?        @relation(fields: [rolId], references: [id], onDelete: SetNull)

  @@unique([usuarioId, restauranteId])
  @@index([restauranteId])
  @@index([restauranteId, activo])
  @@index([usuarioId, activo])
  @@index([rolId])
}

model CuentaOAuth {
  id                 String        @id @default(cuid())
  usuarioId          String
  provider           OAuthProvider
  providerAccountId  String
  createdAt          DateTime      @default(now())

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([usuarioId])
}

model Invitacion {
  id              String    @id @default(cuid())
  restauranteId   String
  email           String
  rolId           String
  tokenHash       String    @unique
  expiraEn        DateTime
  usadaEn         DateTime?
  creadoPorId     String?
  createdAt       DateTime  @default(now())

  restaurante Restaurante @relation(fields: [restauranteId], references: [id], onDelete: Cascade)
  rol         Rol         @relation(fields: [rolId], references: [id], onDelete: Restrict)

  @@index([restauranteId])
  @@index([email])
}

model CodigoVinculacionSucursal {
  id              String    @id @default(cuid())
  restauranteId   String
  codigoHash      String    @unique
  expiraEn        DateTime
  usadaEn         DateTime?
  creadoPorId     String?
  rolId           String?
  organizacionId  String?
  createdAt       DateTime  @default(now())

  restaurante Restaurante  @relation(fields: [restauranteId], references: [id], onDelete: Cascade)
  creadoPor   Usuario?     @relation("CodigoVinculacionCreadoPor", fields: [creadoPorId], references: [id], onDelete: SetNull)
  rol         Rol?         @relation(fields: [rolId], references: [id], onDelete: SetNull)
  organizacion Organizacion? @relation(fields: [organizacionId], references: [id], onDelete: SetNull)

  @@index([restauranteId])
  @@index([expiraEn])
  @@index([usadaEn])
}

model Mesa {
  id        String     @id @default(cuid())
  restauranteId String
  numero    Int
  capacidad Int
  estado    EstadoMesa @default(LIBRE)
  ubicacion String?
  piso      String? // Piso/planta donde está la mesa (ej. "1", "2", "Terraza")
  // Coordenadas espaciales para visualización en planta
  posicionX Float? // Posición X en el plano (0-100 o píxeles)
  posicionY Float? // Posición Y en el plano (0-100 o píxeles)
  rotacion  Float?     @default(0) // Rotación en grados (0-360)
  // Relación con planta (opcional)
  plantaId  String?
  activa    Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  restaurante Restaurante        @relation(fields: [restauranteId], references: [id], onDelete: Restrict)
  planta      PlantaRestaurante? @relation(fields: [plantaId], references: [id])
  comandas    Comanda[]
  publicLink  MesaPublicLink?
  solicitudes SolicitudPedido[]

  @@unique([restauranteId, numero])
  @@index([restauranteId])
}

model Cliente {
  id        String  @id @default(cuid())
  restauranteId String
  nombre    String
  telefono  String?
  direccion String?
  notas     String?

  // Datos Fiscales del Receptor (obligatorios para facturación)
  rfc           String? // RFC del cliente (obligatorio si factura)
  razonSocial   String? // Nombre o razón social exacto (para CFDI)
  regimenFiscal String? // Régimen fiscal del cliente
  codigoPostal  String? // CP del domicilio fiscal del receptor
  usoCFDI       String? @default("G03") // Uso del CFDI (G03=Gastos en general, S01=Sin efectos fiscales)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  restaurante Restaurante @relation(fields: [restauranteId], references: [id], onDelete: Restrict)
  comandas    Comanda[]

  @@index([rfc])
  @@index([restauranteId])
}

model Comanda {
  id              String        @id @default(cuid())
  restauranteId   String
  numeroComanda   String
  mesaId          String?
  clienteId       String?
  tipoPedido      TipoPedido    @default(EN_MESA)
  origen          OrigenComanda @default(STAFF_DASHBOARD)
  estado          EstadoComanda @default(PENDIENTE)
  total           Float
  propina         Float?        @default(0)
  descuento       Float?        @default(0)
  observaciones   String?
  motivoCancelacion String?
  fechaCreacion   DateTime      @default(now())
  fechaCompletado DateTime?
  fechaCancelacion DateTime?
  fechaEntrega    DateTime?
  publicTokenHash String?       @unique
  externalOrderId String?
  externalSource  String?
  creadoPorId     String
  asignadoAId     String?
  canceladoPorId  String?

  restaurante Restaurante        @relation(fields: [restauranteId], references: [id], onDelete: Restrict)
  mesa        Mesa?              @relation(fields: [mesaId], references: [id])
  cliente     Cliente?           @relation(fields: [clienteId], references: [id])
  items     ComandaItem[]
  creadoPor Usuario            @relation("ComandaCreadaPor", fields: [creadoPorId], references: [id])
  asignadoA Usuario?           @relation("ComandaAsignadaA", fields: [asignadoAId], references: [id])
  canceladoPor Usuario?        @relation("ComandaCanceladaPor", fields: [canceladoPorId], references: [id], onDelete: SetNull)
  historial ComandaHistorial[]
  colaboradores ComandaColaborador[]
  pagos     Pago[]
  facturas  Factura[]
  solicitudesOrigen SolicitudPedido[] @relation("SolicitudPedidoComanda")

  @@index([mesaId])
  @@index([estado])
  @@index([fechaCreacion])
  @@index([fechaCompletado])
  @@index([fechaCancelacion])
  @@index([tipoPedido])
  @@index([clienteId])
  @@index([creadoPorId])
  @@index([canceladoPorId])
  @@unique([restauranteId, numeroComanda])
  @@index([estado, fechaCreacion])
  @@index([estado, fechaCompletado])
  @@index([restauranteId])
  @@unique([restauranteId, externalOrderId])
}

model IntegracionPedidosApi {
  id           String   @id @default(cuid())
  restauranteId String  @unique
  apiKeyHash   String
  activo       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  restaurante Restaurante @relation(fields: [restauranteId], references: [id], onDelete: Cascade)
}

model Categoria {
  id          String        @id @default(cuid())
  restauranteId String
  nombre      String
  descripcion String?
  tipo        TipoCategoria
  orden       Int           @default(0)
  activa      Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  restaurante   Restaurante @relation(fields: [restauranteId], references: [id], onDelete: Restrict)
  productos     Producto[]
  modificadores ModificadorCategoria[]

  @@index([tipo])
  @@index([restauranteId])
}

model Producto {
  id              String  @id @default(cuid())
  nombre          String
  descripcion     String?
  precio          Float
  categoriaId     String
  activo          Boolean @default(true)
  listoPorDefault Boolean @default(false) // ej. Coca-Cola: entra en comanda ya como LISTO
  imagenUrl       String?

  // Datos Fiscales del Producto
  objetoImp     String? @default("02") // 01=No objeto, 02=Sí objeto, 03=Sí objeto pero no causa, 04=Sí objeto pero exento
  claveProdServ String? // Clave SAT del producto/servicio
  claveUnidad   String? @default("H87") // Clave de unidad de medida (H87=Pieza)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  categoria        Categoria             @relation(fields: [categoriaId], references: [id])
  items            ComandaItem[]
  solicitudItems   SolicitudPedidoItem[]
  modificadores    ModificadorProducto[]
  tamanos          ProductoTamano[]
  facturaConceptos FacturaConcepto[]

  @@index([categoriaId])
  @@index([activo])
}

// Tamaños por producto: cada platillo define sus propias opciones (Chico $X, Grande $Y, etc.)
model ProductoTamano {
  id         String @id @default(cuid())
  productoId String
  nombre     String // ej. Chico, Mediano, Grande
  precio     Float
  orden      Int    @default(0)

  producto Producto      @relation(fields: [productoId], references: [id], onDelete: Cascade)
  items    ComandaItem[]
  solicitudItems SolicitudPedidoItem[]

  @@unique([productoId, nombre])
  @@index([productoId])
}

model ModificadorProducto {
  id            String @id @default(cuid())
  productoId    String
  modificadorId String

  producto    Producto    @relation(fields: [productoId], references: [id], onDelete: Cascade)
  modificador Modificador @relation(fields: [modificadorId], references: [id], onDelete: Cascade)

  @@unique([productoId, modificadorId])
}

model ModificadorCategoria {
  id            String @id @default(cuid())
  categoriaId   String
  modificadorId String

  categoria   Categoria   @relation(fields: [categoriaId], references: [id], onDelete: Cascade)
  modificador Modificador @relation(fields: [modificadorId], references: [id], onDelete: Cascade)

  @@unique([categoriaId, modificadorId])
}

model ComandaItem {
  id               String      @id @default(cuid())
  comandaId        String
  productoId       String
  tamanoId         String? // Si el producto tiene tamaños, cuál se eligió
  cantidad         Int         @default(1)
  precioUnitario   Float
  subtotal         Float
  notas            String?
  estado           EstadoItem  @default(PENDIENTE)
  numeroRonda      Int         @default(1)
  destino          DestinoItem
  fechaPreparacion DateTime?
  fechaListo       DateTime?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  comanda       Comanda           @relation(fields: [comandaId], references: [id], onDelete: Cascade)
  producto      Producto          @relation(fields: [productoId], references: [id])
  tamano        ProductoTamano?   @relation(fields: [tamanoId], references: [id], onDelete: SetNull)
  modificadores ItemModificador[]
  pagosLinea    PagoLinea[]

  @@index([comandaId])
  @@index([estado])
  @@index([destino])
  @@index([productoId])
  @@index([createdAt])
}

model ItemModificador {
  id            String @id @default(cuid())
  comandaItemId String
  modificadorId String
  precioExtra   Float  @default(0)

  comandaItem ComandaItem @relation(fields: [comandaItemId], references: [id], onDelete: Cascade)
  modificador Modificador @relation(fields: [modificadorId], references: [id])

  @@unique([comandaItemId, modificadorId])
}

model Modificador {
  id          String          @id @default(cuid())
  restauranteId String
  nombre      String
  tipo        TipoModificador
  precioExtra Float?          @default(0)
  activo      Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  restaurante Restaurante           @relation(fields: [restauranteId], references: [id], onDelete: Restrict)
  productos   ModificadorProducto[]
  categorias  ModificadorCategoria[]
  items       ItemModificador[]
  solicitudItems SolicitudItemModificador[]

  @@index([restauranteId])
}

model ComandaHistorial {
  id          String   @id @default(cuid())
  comandaId   String
  accion      String // "CREADA", "ESTADO_CAMBIADO", "ITEM_AGREGADO", etc.
  descripcion String?
  usuarioId   String?
  fechaAccion DateTime @default(now())

  comanda Comanda  @relation(fields: [comandaId], references: [id], onDelete: Cascade)
  usuario Usuario? @relation("ComandaHistorialUsuario", fields: [usuarioId], references: [id])

  @@index([comandaId])
  @@index([fechaAccion])
}

model Auditoria {
  id          String   @id @default(cuid())
  restauranteId String
  usuarioId   String
  accion      String // "LOGIN", "LOGOUT", "CREAR_COMANDA", etc.
  entidad     String? // "Comanda", "Producto", etc.
  entidadId   String?
  detalles    Json?
  fechaAccion DateTime @default(now())

  usuario     Usuario     @relation("AuditoriaUsuario", fields: [usuarioId], references: [id])
  restaurante Restaurante @relation(fields: [restauranteId], references: [id], onDelete: Restrict)

  @@index([usuarioId])
  @@index([fechaAccion])
  @@index([restauranteId])
}

model DashboardVista {
  id          String              @id @default(cuid())
  restauranteId String
  nombre      String
  descripcion String?
  modulo      String              @default("reportes")
  scope       ScopeVistaDashboard @default(USER)
  usuarioId   String?
  rolId       String?
  esDefault   Boolean             @default(false)
  activa      Boolean             @default(true)
  filtros     Json
  widgets     Json
  layout      Json?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  restaurante Restaurante @relation(fields: [restauranteId], references: [id], onDelete: Restrict)
  usuario     Usuario?    @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  rol         Rol?        @relation(fields: [rolId], references: [id], onDelete: SetNull)

  @@index([scope, modulo])
  @@index([usuarioId, modulo])
  @@index([rolId, modulo])
}

model ConfiguracionRestaurante {
  id             String  @id @default(cuid())
  restauranteId  String  @unique
  // Datos Fiscales Obligatorios
  rfc            String?
  nombre         String?
  regimenFiscal  String? // "601", "621", etc.
  codigoPostal   String?
  calle          String?
  numeroExterior String?
  numeroInterior String?
  colonia        String?
  municipio      String?
  estado         String?
  pais           String? @default("MEX")

  // Lugar de Expedición (separado del domicilio fiscal)
  lugarExpedicionCp String? // Código postal del establecimiento que emite facturas

  // Serie y Folio
  serieFactura String? @default("A") // Serie para facturas (ej. POS, A, R1)
  folioInicial Int?    @default(1) // Folio inicial consecutivo
  folioActual  Int?    @default(1) // Folio actual (se incrementa automáticamente)

  // Configuración del Comprobante (valores por defecto)
  tipoComprobante String? @default("I") // I=Ingreso, E=Egreso, T=Traslado, N=Nómina, P=Pago
  exportacion     String? @default("01") // 01=No aplica, 02=Definitiva, 03=Temporal
  moneda          String? @default("MXN")
  tipoCambio      Float? // Solo si se usa otra moneda

  // Configuración Fiscal Operativa
  preciosIncluyenIva       Boolean @default(false) // true = precios incluyen IVA, false = se suma IVA
  tasaIva16                Float?  @default(0.16) // Tasa de IVA 16%
  tasaIva0                 Float?  @default(0.0) // Tasa de IVA 0%
  tasaIeps                 Float?  @default(0.0) // Tasa IEPS (ej. alcohol)
  descuentosAntesImpuestos Boolean @default(true) // true = descuentos antes de impuestos
  redondeo                 String? @default("redondeo") // "redondeo", "truncar", "exacto"

  // Configuración PAC (Facturación)
  pacApiKey      String? // Encriptado
  pacApiUrl      String? @default("https://api.facturacion.com/v1")
  pacModo        String? @default("pruebas") // "pruebas" o "produccion"
  pacConfigurado Boolean @default(false)

  // Configuración Procesador de Pagos
  conektaPrivateKey String? // Encriptado
  conektaPublicKey  String? // Encriptado (para frontend)
  conektaApiVersion String? @default("2.0")
  pagosConfigurado  Boolean @default(false)

  // Certificado de Sello Digital (CSD)
  csdCerPath          String? // Ruta al archivo .cer
  csdKeyPath          String? // Ruta al archivo .key
  csdPassword         String? // Encriptado
  csdVigente          Boolean   @default(false)
  csdFechaVencimiento DateTime?

  // Factura Global (obligatoria en restaurantes)
  facturaGlobalHabilitada         Boolean @default(true)
  facturaGlobalRfcReceptor        String? @default("XAXX010101000") // RFC genérico
  facturaGlobalNombreReceptor     String? @default("PÚBLICO EN GENERAL")
  facturaGlobalRegimenReceptor    String? @default("616") // Régimen para público en general
  facturaGlobalUsoCFDI            String? @default("S01") // Sin efectos fiscales
  facturaGlobalPeriodicidad       String? // "01"=Diario, "02"=Semanal, "03"=Quincenal, "04"=Mensual, "05"=Bimestral
  facturaGlobalMes                Int? // Mes de la factura global
  facturaGlobalAnio               Int? // Año de la factura global
  facturaGlobalPoliticaNominativa String? @default("emitir_sin_ajustar") // Política cuando cliente pide factura después: "emitir_sin_ajustar", "cancelar_global_emitir_nominativa", "ajustar_global_emitir_nominativa"

  // Webhooks
  webhookSecretConekta String? // Encriptado
  webhookUrl           String?

  // Configuración General
  configuracionCompleta Boolean   @default(false)
  configuradoPorId      String? // Usuario que hizo la configuración
  fechaConfiguracion    DateTime?

  // Configuración de Tiempos para Mesas (en minutos)
  tiempoAmarilloMinutos Int? @default(30) // Tiempo para cambiar de verde a amarillo
  tiempoRojoMinutos     Int? @default(60) // Tiempo para cambiar de amarillo a rojo

  // Alerta efectivo bajo (MXN) - banner cuando efectivo en caja < este valor
  alertaEfectivoMinimo Float?

  // Feature flag para flujo de solicitud pública de pedidos (cliente directo)
  pedidosClienteSolicitudHabilitado Boolean @default(false)
  /// Control automático de carga para pedidos por link/QR (límites, cola, mensajes). En API: `controlCargaAutomaticaPedidos`.
  modoDPedidosHabilitado Boolean @default(false)
  queueEnabled           Boolean @default(true)
  qrMesaEnabled          Boolean @default(true)
  maxComandasActivas     Int?    @default(25)
  tiempoEsperaSaturacionMin Int? @default(15)
  mensajeSaturacion      String? @default("Ahorita estamos a tope. Tu pedido podría iniciar en unos minutos. ¿Deseas entrar a la cola?")
  autoAprobarSolicitudes Boolean @default(false)

  // ETA mostrada al cliente en seguimiento (minutos)
  clienteEtaMinMinutos Int? @default(45)
  clienteEtaMaxMinutos Int? @default(60)
  /// Tope de ítems en preparación (cocina/barra) para considerar saturación; null = solo usar tope de comandas activas
  maxItemsPreparacion    Int?

  // Política de Propina
  propinaFacturar  Boolean @default(false) // true = se factura la propina como concepto separado
  propinaObjetoImp String? @default("02") // Objeto de impuesto para propina (02=Sí objeto)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  restaurante Restaurante @relation(fields: [restauranteId], references: [id], onDelete: Cascade)

  @@index([rfc])
}

model MesaPublicLink {
  id            String   @id @default(cuid())
  restauranteId String
  mesaId        String   @unique
  codeHash      String   @unique
  /// Token opaco del query `mesa=` (misma cadena que se hashea en `codeHash`). Solo para staff autenticado vía GET del panel.
  publicCode    String?  @unique
  activa        Boolean  @default(true)
  expiraEn      DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  restaurante Restaurante @relation(fields: [restauranteId], references: [id], onDelete: Cascade)
  mesa        Mesa        @relation(fields: [mesaId], references: [id], onDelete: Cascade)

  @@index([restauranteId])
  @@index([activa])
}

model SolicitudPedido {
  id              String               @id @default(cuid())
  restauranteId   String
  mesaId          String?
  tipoPedido      TipoPedidoSolicitud
  origen          OrigenSolicitudPedido
  estado          EstadoSolicitudPedido @default(PENDIENTE)
  nombreCliente   String
  telefono        String?
  notas           String?
  observaciones   String?
  totalEstimado   Float
  approvedComandaId String?
  decisionSource   String? // AUTO | MANUAL_APPROVE | MANUAL_FORCE | AUTO_QUEUE
  decisionReason   String?
  reviewedById     String?
  enColaAt         DateTime?
  prioridadColaAt  DateTime?
  aprobadaAt      DateTime?
  rechazadaAt     DateTime?
  publicTokenHash   String?   @unique
  publicTokenIssuedAt DateTime?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  restaurante Restaurante       @relation(fields: [restauranteId], references: [id], onDelete: Restrict)
  mesa        Mesa?             @relation(fields: [mesaId], references: [id], onDelete: SetNull)
  approvedComanda Comanda?      @relation("SolicitudPedidoComanda", fields: [approvedComandaId], references: [id], onDelete: SetNull)
  reviewedBy  Usuario?          @relation("SolicitudPedidoRevisadaPor", fields: [reviewedById], references: [id], onDelete: SetNull)
  items       SolicitudPedidoItem[]

  @@index([restauranteId])
  @@index([estado, createdAt])
  @@index([prioridadColaAt])
  @@index([mesaId])
}

model ComandaColaborador {
  id         String   @id @default(cuid())
  comandaId  String
  usuarioId  String
  tipo       String   @default("APOYO_ENTREGA")
  createdAt  DateTime @default(now())

  comanda Comanda @relation(fields: [comandaId], references: [id], onDelete: Cascade)
  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([comandaId, createdAt])
  @@index([usuarioId, createdAt])
  @@unique([comandaId, usuarioId, tipo])
}

model SolicitudPedidoItem {
  id               String     @id @default(cuid())
  solicitudPedidoId String
  productoId       String
  tamanoId         String?
  cantidad         Int
  precioUnitario   Float
  subtotal         Float
  notas            String?
  destino          DestinoItem
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  solicitudPedido SolicitudPedido @relation(fields: [solicitudPedidoId], references: [id], onDelete: Cascade)
  producto        Producto        @relation(fields: [productoId], references: [id])
  tamano          ProductoTamano? @relation(fields: [tamanoId], references: [id], onDelete: SetNull)
  modificadores   SolicitudItemModificador[]

  @@index([solicitudPedidoId])
  @@index([productoId])
  @@index([destino])
}

model SolicitudItemModificador {
  id                 String @id @default(cuid())
  solicitudPedidoItemId String
  modificadorId      String
  precioExtra        Float  @default(0)

  solicitudPedidoItem SolicitudPedidoItem @relation(fields: [solicitudPedidoItemId], references: [id], onDelete: Cascade)
  modificador         Modificador         @relation(fields: [modificadorId], references: [id])

  @@unique([solicitudPedidoItemId, modificadorId])
}

enum EstadoPago {
  PENDIENTE
  COMPLETADO
  FALLIDO
  CANCELADO
}

model Pago {
  id           String     @id @default(cuid())
  comandaId    String
  monto        Float
  metodoPago   String // "tarjeta_credito", "efectivo", "oxxo", etc.
  procesador   String     @default("conekta")
  procesadorId String? // ID del procesador (Conekta, etc.)
  estado       EstadoPago @default(PENDIENTE)
  comision     Float?     @default(0)
  referencia   String? // Para OXXO, SPEI, etc.
  detalles     Json? // Datos adicionales del pago
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  comanda Comanda  @relation(fields: [comandaId], references: [id], onDelete: Cascade)
  factura Factura?
  lineas  PagoLinea[]

  @@index([comandaId])
  @@index([estado])
  @@index([procesadorId])
  @@index([createdAt])
  @@index([metodoPago])
  @@index([estado, createdAt])
}

/// Detalle de cobro por ítem (separación de cuenta y auditoría).
model PagoLinea {
  id            String   @id @default(cuid())
  pagoId        String
  comandaItemId String
  cantidad      Int
  importe       Float
  createdAt     DateTime @default(now())

  pago          Pago         @relation(fields: [pagoId], references: [id], onDelete: Cascade)
  comandaItem   ComandaItem  @relation(fields: [comandaItemId], references: [id], onDelete: Restrict)

  @@index([pagoId])
  @@index([comandaItemId])
}

model Factura {
  id             String   @id @default(cuid())
  comandaId      String
  pagoId         String?  @unique
  uuid           String   @unique // UUID del CFDI
  folio          String?
  serie          String?
  fechaEmision   DateTime
  emisorRfc      String
  receptorRfc    String?
  receptorNombre String
  usoCFDI        String
  subtotal       Float
  iva            Float
  total          Float
  formaPago      String
  metodoPago     String
  xml            String   @db.Text // XML timbrado completo
  pdf            String? // Ruta al PDF generado
  qrCode         String? // Código QR para verificación
  estado         String   @default("activa") // "activa", "cancelada"

  // Cancelación (requisitos SAT)
  motivoCancelacion String? // "01"=Comprobante emitido con errores, "02"=Comprobante no aplicable, "03"=Devolución parcial/total, "04"=Operación nominativa relacionada en factura global
  uuidSustitucion   String? // UUID del CFDI que sustituye (si motivoCancelacion = "01")
  fechaCancelacion  DateTime? // Fecha de cancelación

  // Log Modo Fácil (auditoría)
  detallesEmision Json? // { modo: 'facil', presetId, overrides, timestamp } cuando se emite con asistente

  createdAt DateTime @default(now())

  comanda          Comanda           @relation(fields: [comandaId], references: [id], onDelete: Cascade)
  pago             Pago?             @relation(fields: [pagoId], references: [id])
  conceptos        FacturaConcepto[]
  complementosPago ComplementoPago[]

  @@index([comandaId])
  @@index([uuid])
  @@index([fechaEmision])
  @@index([estado])
}

model FacturaConcepto {
  id            String  @id @default(cuid())
  facturaId     String
  productoId    String?
  claveProdServ String
  cantidad      Float
  claveUnidad   String
  descripcion   String  @db.Text
  valorUnitario Float
  importe       Float

  // Objeto de Impuesto (requisito SAT CFDI 4.0)
  objetoImp String @default("02") // 01=No objeto, 02=Sí objeto, 03=Sí objeto pero no causa, 04=Sí objeto pero exento

  // Impuestos por concepto
  iva      Float  @default(0) // IVA del concepto
  ivaTasa  Float? // Tasa de IVA aplicada (0.16, 0.08, 0.0)
  ieps     Float? @default(0) // IEPS si aplica (ej. alcohol)
  iepsTasa Float? // Tasa de IEPS aplicada

  createdAt DateTime @default(now())

  factura  Factura   @relation(fields: [facturaId], references: [id], onDelete: Cascade)
  producto Producto? @relation(fields: [productoId], references: [id])

  @@index([facturaId])
  @@index([productoId])
}

// Complemento de Pago (para PPD - Pago en Parcialidades o Diferido)
model ComplementoPago {
  id              String   @id @default(cuid())
  facturaId       String // Factura relacionada (puede ser múltiple)
  fechaPago       DateTime // Fecha del pago
  formaPagoP      String // Forma de pago del complemento
  monedaP         String   @default("MXN") // Moneda del pago
  monto           Float // Monto pagado
  numOperacion    String? // Número de operación (transferencia, cheque, etc.)
  rfcEmisorCtaOrd String? // RFC del banco emisor (si aplica)
  nomBancoOrdExt  String? // Nombre del banco (si aplica)
  rfcEmisorCtaBen String? // RFC del banco receptor (si aplica)
  ctaOrdenante    String? // Cuenta ordenante
  ctaBeneficiario String? // Cuenta beneficiaria
  tipoCadPago     String? // Tipo de cadena de pago
  certPago        String? // Certificado de pago
  cadPago         String? // Cadena de pago
  selloPago       String? // Sello del pago

  // Relación con documento original
  uuidDocumento    String? // UUID del CFDI original que se está pagando
  serieDocumento   String? // Serie del documento original
  folioDocumento   String? // Folio del documento original
  monedaDR         String? // Moneda del documento relacionado
  tipoCambioDR     Float? // Tipo de cambio del documento relacionado
  metodoPagoDR     String? // Método de pago del documento relacionado
  numParcialidad   Int? // Número de parcialidad
  impSaldoAnt      Float? // Importe del saldo anterior
  impPagado        Float? // Importe pagado
  impSaldoInsoluto Float? // Importe del saldo insoluto

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  factura Factura @relation(fields: [facturaId], references: [id], onDelete: Cascade)

  @@index([facturaId])
  @@index([uuidDocumento])
  @@index([fechaPago])
}

// Corte X: reporte temporal, NO reinicia la caja
model CorteX {
  id        String   @id @default(cuid())
  restauranteId String
  fechaHora DateTime @default(now())
  usuarioId String

  totalVentas   Float @default(0)
  totalEfectivo Float @default(0)
  totalTarjeta  Float @default(0)
  totalOtros    Float @default(0)
  numComandas   Int   @default(0)
  detalles      Json? // Desglose por método de pago, etc.

  usuario     Usuario     @relation(fields: [usuarioId], references: [id])
  restaurante Restaurante @relation(fields: [restauranteId], references: [id], onDelete: Restrict)

  @@index([fechaHora])
  @@index([usuarioId])
  @@index([restauranteId])
}

// Turno de caja: apertura con fondo inicial, cierre con arqueo
model TurnoCaja {
  id            String    @id @default(cuid())
  restauranteId String
  usuarioId     String
  fechaApertura DateTime  @default(now())
  fechaCierre   DateTime? // null = turno abierto
  fondoInicial  Float     // efectivo al abrir
  fondoCierre   Float?    // efectivo contado al cerrar (arqueo)

  usuario     Usuario     @relation(fields: [usuarioId], references: [id])
  restaurante Restaurante @relation(fields: [restauranteId], references: [id], onDelete: Cascade)

  @@index([restauranteId])
  @@index([fechaApertura])
}

// Corte Z: cierre definitivo del turno/día
model CorteZ {
  id        String   @id @default(cuid())
  restauranteId String
  fechaHora DateTime @default(now())
  usuarioId String

  totalVentas   Float @default(0)
  totalEfectivo Float @default(0)
  totalTarjeta  Float @default(0)
  totalOtros    Float @default(0)
  numComandas   Int   @default(0)
  detalles      Json?

  usuario     Usuario     @relation(fields: [usuarioId], references: [id])
  restaurante Restaurante @relation(fields: [restauranteId], references: [id], onDelete: Restrict)

  @@index([fechaHora])
  @@index([usuarioId])
  @@index([restauranteId])
}

// Planta del restaurante - contorno del cuarto mapeado
model PlantaRestaurante {
  id        String   @id @default(cuid())
  restauranteId String
  nombre    String? // Nombre de la planta/salón (ej. "Salón Principal", "Terraza")
  // Contorno del cuarto como polígono (vértices en coordenadas de celda)
  vertices  Json // Array de {x: number, y: number} en coordenadas de celda
  edges     Json? // Array de {from: number, to: number} índices de vértices
  // Configuración de la cuadrícula
  cellSizeM Float    @default(1.0) // Tamaño de celda en metros
  // Punto de origen (esquina inicial donde se inició el mapeo)
  originX   Float    @default(0)
  originY   Float    @default(0)
  // Dimensiones del canvas en metros (calculadas del polígono)
  widthM    Float?
  heightM   Float?
  // Metadatos
  activa    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  restaurante Restaurante @relation(fields: [restauranteId], references: [id], onDelete: Restrict)
  mesas       Mesa[]

  @@index([restauranteId])
}

model IntegracionClip {
  id              String   @id @default(cuid())
  restauranteId   String   @unique
  apiKeyEncrypted String? // Bearer / API key (encriptado)
  activo          Boolean  @default(false)
  webhookSecret   String? // validar webhooks (encriptado)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  restaurante Restaurante @relation(fields: [restauranteId], references: [id], onDelete: Cascade)
}

model ClipTerminal {
  id            String   @id @default(cuid())
  restauranteId String
  serialNumber  String
  nombre        String?
  activo        Boolean  @default(true)
  isDefault     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  restaurante Restaurante @relation(fields: [restauranteId], references: [id], onDelete: Cascade)

  @@unique([restauranteId, serialNumber])
  @@index([restauranteId])
}
